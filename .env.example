# Copia este archivo a .env y ajusta los valores para producción.
# Solo lo usa docker-compose.yml (producción); el modo dev usa valores fijos.

# ── Frontend ────────────────────────────────────────────────────────
# URL del backend que usa el navegador (se incrusta en build time).
VITE_API_URL=http://localhost:8000

# ── Backend ─────────────────────────────────────────────────────────
# Orígenes permitidos por CORS (separados por coma). En prod debe ser
# el origen desde el que se sirve el frontend (nginx).
CORS_ORIGINS=http://localhost:8080

# Ubicación de la BD SQLite dentro del contenedor (montada en el volumen).
# Nota: 4 barras = ruta absoluta /data/app.db
DATABASE_URL=sqlite:////data/app.db

# ── Puertos publicados en el host (prod) ────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=8000
